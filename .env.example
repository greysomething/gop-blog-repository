# Supabase (new project — NOT the grant portal's)
# New-format projects use sb_publishable_* (browser-safe) and sb_secret_* (server-only).
# Legacy projects use eyJ... anon key + eyJ... service_role key. Either works.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-BLOG-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Anthropic (drafter + scorer)
ANTHROPIC_API_KEY=sk-ant-...

# Cron shared-secret (set same value in Vercel → Settings → Environment Variables)
# Vercel Cron sets Authorization: Bearer <CRON_SECRET> automatically when this is set.
CRON_SECRET=change-me-to-a-long-random-string

# Public site
NEXT_PUBLIC_SITE_URL=https://blog.giftofparenthood.org
